{
  "name": "weixin-clawbot-protocol-sdk",
  "version": "1.0.0",
  "description": "Standalone Weixin ClawBot protocol SDK with a file-backed example app",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "send": "node dist/src/example/send-message/cli.js",
    "send-burst": "node dist/src/example/send-message/burst.js",
    "wechat-automation-send": "node dist/src/example/codex-hook/automation-wechat/cli.js",
    "codex-desktop-send": "node dist/src/example/codex-hook/automation-codex-desktop/cli.js",
    "codex-hook": "node dist/src/example/codex-hook/cli.js",
    "codex-hook-daemon": "node dist/src/example/codex-hook/daemon.js"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.0"
  }
}
